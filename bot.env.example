#Telegram bot token of the bot
VAALILAKANABOT_TOKEN=

#Telegram's numeric chat id of the admin chat
ADMIN_CHAT_ID=

# Google Sheets Configuration
# Full URL of the Google Sheets document
# Example: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_SHEET_URL=

#Base URL of the Discource server
BASE_URL=

#Api key for updating the vaalilakana post
#Look at Fiirumi Admin Panel -> API to generate an API key
API_KEY=

#Api username for updating the vaalilakana post
#Look at Fiirumi Admin Panel -> API to generate an API key
API_USERNAME=

# Set to the current election year (e.g. 2025). Bot creates categories and derives all Fiirumi URLs from this.
# Format: YYYY
ELECTION_YEAR=
