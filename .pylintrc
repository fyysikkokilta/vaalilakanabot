[BASIC]
argument-rgx=[a-z_][a-z0-9_]{0,30}
attr-rgx=[a-z_][a-z0-9_]{0,30}
const-rgx=[a-zA-Z_][a-zA-Z0-9_]{0,30}
variable-rgx=[a-zA-Z_][a-zA-Z0-9_]{0,30}

[FORMAT]
max-line-length=160

[MESSAGES CONTROL]
disable=
    broad-except,
    too-many-locals,
    too-many-arguments,
    too-many-statements,
    too-many-nested-blocks,
    too-many-return-statements,
    too-many-public-methods,

[TYPECHECK]
generated-members =